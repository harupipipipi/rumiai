# === git root (rumi_ai/) 用 ===
# rumi_ai_1_10/ と rumi_launcher/ 以外は全て無視
/*
!.gitignore
!/rumi_ai_1_10/
!/rumi_launcher/

# === 共通の不要ファイル ===
venv/
__pycache__/
*.pyc
.DS_Store
*.exe
*.zip
*.bak
*.bak.*
.env.local
node_modules/
dist/

# === rumi_ai_1_10/ 内の不要ファイル ===
chats/
userdata/
tenpu/
debug.txt
erroer_memo.txt
flow.iranai
.backups/
.backup_dead_code_removal/
deploy.py
