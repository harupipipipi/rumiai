{
  "function_id": "exec",
  "description": "実行中コンテナでコマンドを実行する",
  "requires": [
    "docker.exec"
  ],
  "caller_requires": [],
  "host_execution": false,
  "tags": [
    "docker",
    "container"
  ],
  "input_schema": {
    "type": "object",
    "properties": {
      "container_id": {
        "type": "string",
        "description": "Name or ID of the running container"
      },
      "command": {
        "type": "string",
        "description": "Command to execute inside the container"
      },
      "timeout": {
        "type": "number",
        "description": "Execution timeout in seconds",
        "default": 30
      }
    },
    "required": [
      "container_id",
      "command"
    ]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "exit_code": {
        "type": "integer",
        "description": "Process exit code"
      },
      "stdout": {
        "type": "string",
        "description": "Standard output from the command"
      },
      "stderr": {
        "type": "string",
        "description": "Standard error from the command"
      }
    },
    "required": [
      "exit_code",
      "stdout",
      "stderr"
    ]
  },
  "grant_config": {
    "allowed_images": [],
    "max_execution_time": 300
  }
}
